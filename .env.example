# Scroll.io Environment Variables Configuration

# ------------------------------------------------------------------------------
# 1. Database Configuration
# Connect to your PostgreSQL database (e.g. Neon, Supabase, AWS RDS)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://username:password@hostname:5432/database_name?sslmode=require

# ------------------------------------------------------------------------------
# 2. API Server Configuration
# The port where your Express API server will listen
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=production

# ------------------------------------------------------------------------------
# 3. JWT Secret Configuration
# Secret key used to sign and verify user authentication tokens (make this strong and unique!)
# ------------------------------------------------------------------------------
JWT_SECRET=your_super_secret_key_here
