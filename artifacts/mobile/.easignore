# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Credentials and secrets (keep ignored)
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
.vercel

.env

# Native generated/build artifacts — keep the android/ & ios/ project sources (so our
# build.gradle fix is used) but never upload local-machine build state or SDK paths.
# EAS compiles these fresh on the build server.
android/local.properties
android/.gradle/
android/.kotlin/
android/build/
android/app/build/
**/.cxx/
ios/build/
ios/Pods/
